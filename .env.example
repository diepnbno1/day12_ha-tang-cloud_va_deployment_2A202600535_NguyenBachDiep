# Copy to .env.local for local Docker usage.
# Never commit .env.local or real secret values.

HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=false

APP_NAME=Production AI Agent
APP_VERSION=1.0.0

OPENAI_API_KEY=
LLM_MODEL=mock-llm

AGENT_API_KEY=dev-key-change-me
JWT_SECRET=dev-jwt-secret
JWT_EXPIRE_MINUTES=60
DEMO_USERNAME=admin
DEMO_PASSWORD=secret

RATE_LIMIT_PER_MINUTE=10
ADMIN_RATE_LIMIT_PER_MINUTE=100
MONTHLY_BUDGET_USD=10.0
PRICE_PER_1K_INPUT_TOKENS=0.00015
PRICE_PER_1K_OUTPUT_TOKENS=0.0006

REDIS_URL=redis://localhost:6379/0
HISTORY_MAX_MESSAGES=20
HISTORY_TTL_SECONDS=2592000

ALLOWED_ORIGINS=http://localhost:3000,http://localhost
